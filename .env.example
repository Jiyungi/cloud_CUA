# Cloud CUA local credentials template.
# Copy values into ~/.cloud-cua/credentials.env for normal use.
# Do not commit real keys.

# Required for H Company CUA / Holo / H agents.
HAI_API_KEY=

# Optional. Enables Teach Mode voice input/output through Gradium.
GRADIUM_API_KEY=

# Optional Docker Compose target. Defaults to the Cloud CUA checkout.
# Set this to the local app repository the container should analyze.
CLOUD_CUA_REPO_PATH=

# Host port for the Docker dashboard. Change this if port 3000 is in use.
CLOUD_CUA_DOCKER_PORT=3000
